  "prettier": "@easymart/prettier-config",
  "dependencies": {
    "react": "catalog:react-19",
    "react-dom": "catalog:react-19",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@easymart/database": "workspace:*",
    "@easymart/eslint-config": "workspace:*",
    "@easymart/prettier-config": "workspace:*",
    "@easymart/typescript-config": "workspace:*",
    "@types/react": "catalog:react-19",
    "@types/react-dom": "catalog:react-19",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vite": "^6.3.5",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
