{
  "name": "@easymart/shop",
  "private": true,
  "description": "Frontend application for the EasyMart project",
  "license": "ISC",
  "author": "Vladyslav Kolhanov",
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build",
    "dev": "vite",
