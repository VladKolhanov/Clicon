{
  "$schema": "https://json.schemastore.org/tsconfig",
  "include": [
    "${configDir}/**/*",
  ],
  "compilerOptions": {
    "rootDir": "${configDir}",
    "outDir": "${configDir}/dist",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "jsx": "react-jsx",
    
    "baseUrl": "${configDir}",
    "paths": {
      "~/*": ["${configDir}/src/*"]
    },
    "verbatimModuleSyntax": true
  }
}

